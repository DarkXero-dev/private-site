---
// Tech specs — StationXero rig
const mainSpecs = [
  { label: 'GPU', value: 'AMD RX 7800XT' },
  { label: 'CPU', value: 'AMD Ryzen 9 5950X' },
  { label: 'OS', value: 'XeroLinux + Windows 11' },
  { label: 'DE/Session', value: 'KDE Plasma Wayland' },
  { label: 'Memory', value: '32GB DDR4 @ 3200Mt/s' },
];
---

<div class="max-w-4xl mx-auto flex flex-col gap-4 h-full justify-center">
  <h2 class="font-[family-name:var(--font-heading)] text-lg text-[var(--color-accent)]">Rig</h2>

  <div class="info-card rig-card p-4 relative overflow-hidden">
    <!-- Subtle scanlines -->
    <div class="pointer-events-none absolute inset-0 opacity-[0.02]" style="background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(124,106,239,0.5) 2px,rgba(124,106,239,0.5) 4px)"></div>
    <!-- Corner brackets -->
    <div class="absolute top-2 left-2 w-5 h-5 border-t border-l border-[var(--color-accent)]/30"></div>
    <div class="absolute top-2 right-2 w-5 h-5 border-t border-r border-[var(--color-accent)]/30"></div>
    <div class="absolute bottom-2 left-2 w-5 h-5 border-b border-l border-[var(--color-accent)]/30"></div>
    <div class="absolute bottom-2 right-2 w-5 h-5 border-b border-r border-[var(--color-accent)]/30"></div>

    <div class="relative z-10 space-y-3">
      <div class="flex items-center gap-3">
        <span class="font-[family-name:var(--font-mono)] text-[11px] text-[var(--color-accent)] tracking-widest uppercase">StationXero</span>
        <span class="text-[var(--color-text-muted)] text-[11px]">// Daily Driver</span>
        <span class="ml-auto inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[10px] font-[family-name:var(--font-mono)] uppercase tracking-wider bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          Online
        </span>
      </div>

      <!-- Rig Image with hover shine effect -->
      <div class="group relative rounded-lg overflow-hidden border border-[var(--color-border)]">
        <img
          src="/desktop.webp"
          alt="StationXero Setup"
          class="w-full h-auto transition-transform duration-700 group-hover:scale-[1.02]"
          loading="lazy"
        />
        <!-- Shine sweep on hover -->
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/8 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000 ease-in-out pointer-events-none"></div>
        <!-- Subtle permanent vignette -->
        <div class="absolute inset-0 pointer-events-none" style="box-shadow: inset 0 0 60px rgba(0,0,0,0.4);"></div>
      </div>

      <div class="flex flex-wrap gap-3">
        {mainSpecs.map((spec) => (
          <div class="spec-row flex-col items-start gap-0.5">
            <span class="spec-label">{spec.label}</span>
            <span class="text-xs text-[var(--color-text-primary)]">{spec.value}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Decorative elements below the card -->
  <div class="hidden md:flex items-center gap-4">
    <!-- Hex stream -->
    <div class="flex-1 overflow-hidden h-5 relative">
      <div class="rig-hex-scroll font-[family-name:var(--font-mono)] text-[9px] text-[var(--color-accent)]/20 whitespace-nowrap absolute">
        4A 2F 8C E1 37 B5 09 D4 A8 6C 1F 03 7E 5B 92 C0 F3 68 A4 2D 11 BF 56 E8 CA 7D 3E 90 05 41 B7 6F 89 DC 23 75 E6 40 FC 1A 52 8B D7 4E 63 0F A5 38 B1 9C 67 AD 2E F0 84 59 C3 76 18 EB 4D A2 3F D5 0E 5A C8 F1 93 27 B4 6D &nbsp;&nbsp;&nbsp; 4A 2F 8C E1 37 B5 09 D4 A8 6C 1F 03 7E 5B 92 C0 F3 68 A4 2D 11 BF 56 E8 CA 7D 3E 90 05 41 B7 6F 89 DC 23 75 E6 40 FC 1A 52 8B D7 4E 63 0F A5 38 B1 9C 67 AD 2E F0 84 59 C3 76 18 EB 4D A2 3F D5 0E 5A C8 F1 93 27 B4 6D
      </div>
    </div>
  </div>

  <!-- Activity bars -->
  <div class="hidden md:grid grid-cols-3 gap-3">
    <div class="info-card p-3 space-y-1.5">
      <div class="flex items-center justify-between">
        <span class="font-[family-name:var(--font-mono)] text-[9px] text-[var(--color-text-muted)] uppercase tracking-wider">CPU Load</span>
        <span class="font-[family-name:var(--font-mono)] text-[9px] text-[var(--color-accent)]">23%</span>
      </div>
      <div class="flex gap-[2px] h-3 items-end">
        {Array.from({ length: 24 }).map((_, i) => {
          const heights = [30,45,25,60,40,35,55,20,50,30,65,45,35,50,25,40,55,30,45,60,35,25,50,40];
          return <div class="flex-1 rounded-[1px] rig-bar" style={`height:${heights[i]}%;background:var(--color-accent);opacity:0.4;animation:rig-bar-pulse 3s ease-in-out ${i * 0.12}s infinite alternate`}></div>
        })}
      </div>
    </div>
    <div class="info-card p-3 space-y-1.5">
      <div class="flex items-center justify-between">
        <span class="font-[family-name:var(--font-mono)] text-[9px] text-[var(--color-text-muted)] uppercase tracking-wider">Memory</span>
        <span class="font-[family-name:var(--font-mono)] text-[9px] text-emerald-400">8.2 / 64 GB</span>
      </div>
      <div class="h-1.5 rounded-full bg-[var(--color-border)] overflow-hidden">
        <div class="h-full rounded-full bg-emerald-500/60 rig-mem-bar" style="width:13%"></div>
      </div>
    </div>
    <div class="info-card p-3 space-y-1.5">
      <div class="flex items-center justify-between">
        <span class="font-[family-name:var(--font-mono)] text-[9px] text-[var(--color-text-muted)] uppercase tracking-wider">GPU Temp</span>
        <span class="font-[family-name:var(--font-mono)] text-[9px] text-[var(--color-accent)]">48&deg;C</span>
      </div>
      <div class="flex gap-[2px] h-3 items-end">
        {Array.from({ length: 24 }).map((_, i) => {
          const heights = [50,48,52,47,53,49,51,48,50,52,47,53,50,48,51,49,52,50,48,53,47,51,49,50];
          return <div class="flex-1 rounded-[1px]" style={`height:${heights[i]}%;background:var(--color-accent);opacity:0.3;animation:rig-bar-pulse 4s ease-in-out ${i * 0.15}s infinite alternate`}></div>
        })}
      </div>
    </div>
  </div>

  <!-- Circuit trace decoration -->
  <div class="hidden md:block">
    <svg class="w-full h-8 opacity-[0.08]" viewBox="0 0 800 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 16h120l8-8h40l8 8h80l8 8h40l8-8h120l8-8h40l8 8H800" stroke="var(--color-accent)" stroke-width="1"/>
      <circle cx="128" cy="8" r="3" fill="var(--color-accent)"/>
      <circle cx="264" cy="24" r="3" fill="var(--color-accent)"/>
      <circle cx="400" cy="16" r="2" fill="var(--color-accent)"/>
      <circle cx="536" cy="8" r="3" fill="var(--color-accent)"/>
      <circle cx="672" cy="16" r="2" fill="var(--color-accent)"/>
    </svg>
  </div>
</div>

<style>
  .rig-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(124,106,239,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .rig-card::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: conic-gradient(from 0deg, transparent 0%, transparent 96%, rgba(124,106,239,0.08) 98%, transparent 100%);
    animation: rig-sweep 8s linear infinite;
    pointer-events: none;
  }
  @keyframes rig-sweep {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes rig-bar-pulse {
    0% { opacity: 0.2; }
    100% { opacity: 0.6; }
  }
  .rig-hex-scroll {
    animation: rig-hex-drift 30s linear infinite;
  }
  @keyframes rig-hex-drift {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .rig-mem-bar {
    animation: rig-mem-breathe 4s ease-in-out infinite alternate;
  }
  @keyframes rig-mem-breathe {
    0% { width: 12%; }
    100% { width: 15%; }
  }
</style>
