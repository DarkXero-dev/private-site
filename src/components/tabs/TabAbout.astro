---
// About tab — bio with structured sections matching site design
const birthYear = 1980;
const birthMonth = 7; // August (0-indexed)
const now = new Date();
let age = now.getFullYear() - birthYear;
if (now.getMonth() < birthMonth) {
  age--;
}
---

<div class="max-w-4xl mx-auto space-y-8">
  <h2 class="font-[family-name:var(--font-heading)] text-lg text-[var(--color-accent)]">About Me</h2>

  <!-- Bio Card -->
  <div class="info-card p-5">
    <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
      My name's <strong class="text-[var(--color-text-primary)]">Steve</strong>, A.K.A
      <strong class="text-[var(--color-accent)]">TechXero/DarkXero</strong>, and I am a {age} year old
      Tech fanatic from <strong class="text-[var(--color-text-primary)]">Lebanon</strong>. I love technology,
      mainly Computer Hardware/Software, smartphones, and some web-design. I also love many music genres,
      like all types of Electronic mostly anything with hard bass, classic 80's, Heavy Metal, Country, among others.
    </p>
  </div>

  <!-- Music Section -->
  <div class="space-y-3">
    <h3 class="font-[family-name:var(--font-heading)] text-sm text-[var(--color-accent)] uppercase tracking-widest">
      Music
    </h3>
    <div class="info-card p-5">
      <div class="video-wrap">
        <iframe
          src="https://www.youtube.com/embed/NsBiI-LyVm4"
          title="About Me — Music"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>

  <!-- Films Section -->
  <div class="space-y-3">
    <h3 class="font-[family-name:var(--font-heading)] text-sm text-[var(--color-accent)] uppercase tracking-widest">
      Films
    </h3>
    <div class="info-card p-5 space-y-4">
      <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
        Films too, especially Art Films by famous Directors like
        <strong class="text-[var(--color-text-primary)]">Lars Von Trier</strong>,
        <strong class="text-[var(--color-text-primary)]">Tarkovsky</strong>,
        <strong class="text-[var(--color-text-primary)]">Kubrick</strong>,
        <strong class="text-[var(--color-text-primary)]">Francis Ford Coppola</strong>,
        <strong class="text-[var(--color-text-primary)]">George Lucas</strong> and others.
        Don't get me wrong, I do like some of the commercial movies coming out today, but not all.
        These days they tend to do remakes rather than come up with new stuff...
      </p>
      <div class="video-wrap">
        <iframe
          src="https://www.youtube.com/embed/6IZGwvxhXvw"
          title="About Me — Films"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>

  <!-- Platforms Section -->
  <div class="space-y-3">
    <h3 class="font-[family-name:var(--font-heading)] text-sm text-[var(--color-accent)] uppercase tracking-widest">
      Platforms
    </h3>
    <div class="info-card p-5">
      <div class="rounded-lg overflow-hidden">
        <img src="/ios-android.png" alt="iOS and Android" class="w-full h-auto" loading="lazy" />
      </div>
    </div>
    <div class="info-card p-5 space-y-4">
      <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
        I am an avid <strong class="text-[var(--color-text-primary)]">iOS</strong> user when it comes to smartphones.
        I did use <strong class="text-[var(--color-text-primary)]">Android</strong> for 5 years, was happy on it for a while,
        I moved to iOS and have been a happy man ever since. However, it's not to say that I will stick with it for good,
        who knows what the future holds? I might go back to Android... I use both in parallel now to see where I will land...
      </p>
      <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
        In essence, I am a <em class="text-[var(--color-text-primary)] not-italic font-medium">Multi-User</em> — I don't stick to one platform, I like to dabble in all of them,
        but my main passion is <strong class="text-[var(--color-text-primary)]">Linux</strong>.
      </p>
    </div>
  </div>

  <!-- Background -->
  <div class="space-y-3">
    <h3 class="font-[family-name:var(--font-heading)] text-sm text-[var(--color-accent)] uppercase tracking-widest">
      Background
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div class="info-card p-4 space-y-2">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <h4 class="font-[family-name:var(--font-heading)] text-sm font-bold text-[var(--color-text-primary)]">Apple</h4>
        </div>
        <p class="text-xs text-[var(--color-text-secondary)]">Landed a job at Apple in 2019 in Ireland. But it didn't last long unfortunately. At least I can say that I have worked for that company LoL...</p>
        <span class="font-[family-name:var(--font-mono)] text-xs text-[var(--color-accent)]">Cork, Ireland &middot; 2019</span>
      </div>
      <div class="info-card p-4 space-y-2">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <h4 class="font-[family-name:var(--font-heading)] text-sm font-bold text-[var(--color-text-primary)]">Freelance</h4>
        </div>
        <p class="text-xs text-[var(--color-text-secondary)]">Freelance Technical Support specialist — I help people with their tech problems from time to time.</p>
        <span class="font-[family-name:var(--font-mono)] text-xs text-[var(--color-accent)]">Lebanon &middot; Ongoing</span>
      </div>
    </div>
  </div>

  <!-- Passions -->
  <div class="space-y-3">
    <h3 class="font-[family-name:var(--font-heading)] text-sm text-[var(--color-accent)] uppercase tracking-widest">
      Passions
    </h3>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {['Hardware Tinkering', 'Web Design', 'Open Source', 'Multi-Platform Workflows'].map((item) => (
        <div class="info-card p-4 text-center">
          <span class="text-sm text-[var(--color-text-secondary)]">{item}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- XeroLinux -->
  <div class="info-card p-5">
    <div class="rounded-lg overflow-hidden">
      <img src="/xerolinux.png" alt="XeroLinux" class="w-full h-auto" loading="lazy" />
    </div>
  </div>
  <div class="info-card p-5">
    <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
      I currently maintain my very own ArchLinux Distro
      <a href="https://xerolinux.xyz" target="_blank" rel="noopener noreferrer"
         class="text-[var(--color-accent)] hover:text-[var(--color-accent-light)] transition-colors hover:underline">XeroLinux</a>.
      An innovative Arch-based distribution designed to demystify the installation process while preserving user-driven customization.
      I mainly use it above any other OS because that's where my passion lies. <strong class="text-[var(--color-text-primary)]">F.O.S.S</strong> is the way. You can quote me on that LoL...
    </p>
  </div>

  <!-- Desktop-only: Arch Tips Terminal -->
  <div class="hidden lg:flex lg:flex-col info-card p-4 overflow-hidden h-[320px]">
    <div class="flex items-center gap-2 mb-3 shrink-0">
      <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
      <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
      <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
      <span class="font-[family-name:var(--font-mono)] text-[10px] text-[var(--color-text-muted)] ml-2">steve@stationxero:~$</span>
    </div>
    <div id="hacker-terminal" class="font-[family-name:var(--font-mono)] text-[11px] leading-[1.6] overflow-y-auto flex-1 scroll-smooth">
    </div>
  </div>
</div>

<script>
  const terminal = document.getElementById('hacker-terminal');
  if (terminal && window.innerWidth >= 1024) {
    const green = 'color:#4ade80';
    const cyan = 'color:#22d3ee';
    const yellow = 'color:#facc15';
    const red = 'color:#f87171';
    const muted = 'color:#6e7a8a';
    const white = 'color:#e6edf3';
    const accent = 'color:#7c6aef';
    const orange = 'color:#fb923c';

    const MAX_LINES = 80;

    const sequences = [
      [
        { text: '# Tip: Update your system', style: muted },
        { text: '$ sudo pacman -Syu', style: white },
        { text: ':: Synchronizing package databases...', style: muted },
        { text: ' core                  134.2 KiB  1284 KiB/s 00:00', style: green },
        { text: ' extra                   8.6 MiB  12.4 MiB/s 00:01', style: green },
        { text: ' multilib              134.8 KiB  2048 KiB/s 00:00', style: green },
        { text: ':: Starting full system upgrade...', style: muted },
        { text: 'resolving dependencies...', style: muted },
        { text: 'Packages (3) linux-6.12.9-1  mesa-24.3.4-1  firefox-134.0.2-1', style: yellow },
        { text: 'Total Installed Size:   487.21 MiB', style: cyan },
        { text: '(3/3) upgrading firefox               [################] 100%', style: green },
        { text: '', style: muted },
      ],
      [
        { text: '# Tip: Search for a package', style: muted },
        { text: '$ pacman -Ss neovim', style: white },
        { text: 'extra/neovim 0.10.4-1', style: cyan },
        { text: '    Vim-fork focused on extensibility and agility', style: muted },
        { text: 'extra/neovim-qt 0.2.18-3', style: cyan },
        { text: '    Neovim client library and GUI', style: muted },
        { text: '', style: muted },
        { text: '# Tip: Get info about an installed package', style: muted },
        { text: '$ pacman -Qi neovim', style: white },
        { text: 'Name            : neovim', style: green },
        { text: 'Version         : 0.10.4-1', style: green },
        { text: 'Installed Size  : 32.41 MiB', style: green },
        { text: 'Depends On      : luajit  libvterm  unibilium  libtermkey  tree-sitter', style: yellow },
        { text: '', style: muted },
      ],
      [
        { text: '# Tip: Remove orphaned packages', style: muted },
        { text: '$ pacman -Qdtq', style: white },
        { text: 'lib32-libxml2', style: yellow },
        { text: 'perl-xml-parser', style: yellow },
        { text: 'python-setuptools', style: yellow },
        { text: '$ sudo pacman -Rns $(pacman -Qdtq)', style: white },
        { text: 'checking dependencies...', style: muted },
        { text: 'Packages (3) lib32-libxml2-2.13.5-1  perl-xml-parser-2.47-2  python-setuptools-75.8.0-1', style: cyan },
        { text: 'Total Removed Size:  12.84 MiB', style: green },
        { text: ':: Do you want to remove these packages? [Y/n] Y', style: white },
        { text: '(3/3) removing python-setuptools       [################] 100%', style: green },
        { text: '', style: muted },
      ],
      [
        { text: '# Tip: Use paru for AUR packages', style: muted },
        { text: '$ paru -S visual-studio-code-bin', style: white },
        { text: ':: Resolving dependencies...', style: muted },
        { text: ':: Found visual-studio-code-bin in AUR', style: cyan },
        { text: ' Aur (1) visual-studio-code-bin-1.96.4-1', style: green },
        { text: ':: Review PKGBUILD? [Y/n] n', style: white },
        { text: '==> Making package: visual-studio-code-bin 1.96.4-1', style: muted },
        { text: '==> Retrieving sources...', style: muted },
        { text: '  -> Downloading code_1.96.4_amd64.deb...', style: green },
        { text: '(1/1) installing visual-studio-code-bin [################] 100%', style: green },
        { text: '', style: muted },
      ],
      [
        { text: '# Tip: Check system logs with journalctl', style: muted },
        { text: '$ journalctl -b -p err --no-pager | tail -8', style: white },
        { text: 'Apr 07 09:12:03 stationxero kernel: ACPI Error: Namespace lookup failure', style: red },
        { text: 'Apr 07 09:12:04 stationxero systemd[1]: Failed to start bluetooth.service', style: red },
        { text: '', style: muted },
        { text: '# Tip: Follow logs in real time', style: muted },
        { text: '$ journalctl -f -u NetworkManager', style: white },
        { text: 'Apr 07 14:21:03 stationxero NetworkManager[482]: <info>  connectivity: full', style: green },
        { text: 'Apr 07 14:21:04 stationxero NetworkManager[482]: <info>  device (wlan0): state change: activated', style: green },
        { text: '', style: muted },
      ],
      [
        { text: '# Tip: Manage services with systemctl', style: muted },
        { text: '$ systemctl list-units --type=service --state=running | head -8', style: white },
        { text: 'UNIT                     LOAD   ACTIVE SUB     DESCRIPTION', style: yellow },
        { text: 'NetworkManager.service   loaded active running Network Manager', style: green },
        { text: 'bluetooth.service        loaded active running Bluetooth service', style: green },
        { text: 'cronie.service           loaded active running Periodic Command Scheduler', style: green },
        { text: 'sddm.service             loaded active running Simple Desktop Display Manager', style: green },
        { text: 'sshd.service             loaded active running OpenSSH Daemon', style: green },
        { text: '', style: muted },
        { text: '# Tip: Enable a service at boot', style: muted },
        { text: '$ sudo systemctl enable --now sshd', style: white },
        { text: 'Created symlink /etc/systemd/system/multi-user.target.wants/sshd.service', style: cyan },
        { text: '', style: muted },
      ],
      [
        { text: '# Tip: Clean pacman cache', style: muted },
        { text: '$ sudo paccache -r', style: white },
        { text: '==> finished: 42 packages removed (disk space saved: 1.2 GiB)', style: green },
        { text: '', style: muted },
        { text: '# Tip: Keep only the latest cached version', style: muted },
        { text: '$ sudo paccache -rk1', style: white },
        { text: '==> finished: 87 packages removed (disk space saved: 2.8 GiB)', style: green },
        { text: '', style: muted },
        { text: '# Tip: Remove all uninstalled package caches', style: muted },
        { text: '$ sudo paccache -ruk0', style: white },
        { text: '==> finished: 23 packages removed (disk space saved: 412 MiB)', style: green },
        { text: '', style: muted },
      ],
      [
        { text: '# Tip: Check disk usage', style: muted },
        { text: '$ df -h / /home /boot', style: white },
        { text: 'Filesystem      Size  Used Avail Use% Mounted on', style: yellow },
        { text: '/dev/nvme0n1p2  100G   42G   54G  44% /', style: green },
        { text: '/dev/nvme0n1p3  800G  234G  526G  31% /home', style: green },
        { text: '/dev/nvme0n1p1  512M  128M  384M  26% /boot', style: green },
        { text: '', style: muted },
        { text: '# Tip: Find large files', style: muted },
        { text: '$ du -sh ~/.cache/* | sort -rh | head -5', style: white },
        { text: '4.2G    /home/steve/.cache/paru', style: yellow },
        { text: '1.8G    /home/steve/.cache/mozilla', style: yellow },
        { text: '892M    /home/steve/.cache/mesa_shader_cache', style: cyan },
        { text: '324M    /home/steve/.cache/thumbnails', style: cyan },
        { text: '218M    /home/steve/.cache/yay', style: cyan },
        { text: '', style: muted },
      ],
      [
        { text: '# Tip: List explicitly installed packages', style: muted },
        { text: '$ pacman -Qe | wc -l', style: white },
        { text: '287', style: green },
        { text: '', style: muted },
        { text: '# Tip: List recently installed packages', style: muted },
        { text: '$ expac --timefmt="%Y-%m-%d" "%l\\t%n" | sort -r | head -8', style: white },
        { text: '2026-04-07\tfirefox', style: cyan },
        { text: '2026-04-06\tneovim', style: cyan },
        { text: '2026-04-06\ttree-sitter', style: cyan },
        { text: '2026-04-05\tlinux', style: cyan },
        { text: '2026-04-05\tmesa', style: cyan },
        { text: '2026-04-04\tgit', style: cyan },
        { text: '2026-04-03\tkde-applications-meta', style: cyan },
        { text: '2026-04-02\tpipewire', style: cyan },
        { text: '', style: muted },
      ],
      [
        { text: '# Tip: Rebuild the initramfs', style: muted },
        { text: '$ sudo mkinitcpio -P', style: white },
        { text: '==> Building image from preset: /etc/mkinitcpio.d/linux.preset', style: muted },
        { text: '==> Starting build: linux', style: muted },
        { text: '  -> Running build hook: [base]', style: cyan },
        { text: '  -> Running build hook: [udev]', style: cyan },
        { text: '  -> Running build hook: [autodetect]', style: cyan },
        { text: '  -> Running build hook: [modconf]', style: cyan },
        { text: '  -> Running build hook: [encrypt]', style: cyan },
        { text: '  -> Running build hook: [filesystems]', style: cyan },
        { text: '==> Generating module dependencies', style: muted },
        { text: '==> Creating compressed initramfs image: /boot/initramfs-linux.img', style: green },
        { text: '==> Image generation successful', style: green },
        { text: '', style: muted },
      ],
      [
        { text: '# Tip: Check for .pacnew config files', style: muted },
        { text: '$ sudo pacdiff', style: white },
        { text: '==> pacnew file found for /etc/pacman.conf', style: yellow },
        { text: ':: (V)iew, (S)kip, (R)emove, (O)verwrite, (Q)uit: [v/s/r/o/q]', style: white },
        { text: '', style: muted },
        { text: '# Tip: Find all .pacnew files on the system', style: muted },
        { text: '$ find /etc -name "*.pacnew" 2>/dev/null', style: white },
        { text: '/etc/pacman.conf.pacnew', style: yellow },
        { text: '/etc/makepkg.conf.pacnew', style: yellow },
        { text: '', style: muted },
      ],
      [
        { text: '# Tip: Check which package owns a file', style: muted },
        { text: '$ pacman -Qo /usr/bin/git', style: white },
        { text: '/usr/bin/git is owned by git 2.48.1-1', style: green },
        { text: '', style: muted },
        { text: '# Tip: List files installed by a package', style: muted },
        { text: '$ pacman -Ql neovim | head -8', style: white },
        { text: 'neovim /usr/', style: cyan },
        { text: 'neovim /usr/bin/', style: cyan },
        { text: 'neovim /usr/bin/nvim', style: cyan },
        { text: 'neovim /usr/lib/', style: cyan },
        { text: 'neovim /usr/lib/nvim/', style: cyan },
        { text: 'neovim /usr/share/', style: cyan },
        { text: 'neovim /usr/share/nvim/', style: cyan },
        { text: 'neovim /usr/share/nvim/runtime/', style: cyan },
        { text: '', style: muted },
      ],
      [
        { text: '# Tip: Verify package integrity', style: muted },
        { text: '$ pacman -Qkk linux | head -5', style: white },
        { text: 'linux: 22 total files, 0 altered files', style: green },
        { text: '', style: muted },
        { text: '# Tip: Check for broken symlinks', style: muted },
        { text: '$ find /usr/lib -xtype l 2>/dev/null | head -5', style: white },
        { text: '(no broken symlinks found)', style: green },
        { text: '', style: muted },
        { text: '# Tip: Downgrade a package', style: muted },
        { text: '$ sudo pacman -U /var/cache/pacman/pkg/mesa-24.3.3-1-x86_64.pkg.tar.zst', style: white },
        { text: 'loading packages...', style: muted },
        { text: '(1/1) downgrading mesa                 [################] 100%', style: yellow },
        { text: '', style: muted },
      ],
      [
        { text: '# Tip: Mirror management with reflector', style: muted },
        { text: '$ sudo reflector --country "Germany,France" --age 12 --protocol https --sort rate --save /etc/pacman.d/mirrorlist', style: white },
        { text: '[2026-04-07 14:30] INFO: rating 20 mirrors by download speed', style: muted },
        { text: '[2026-04-07 14:31] INFO: Server 1 rate: 24.82 MiB/s', style: green },
        { text: '[2026-04-07 14:31] INFO: Server 2 rate: 21.47 MiB/s', style: green },
        { text: '[2026-04-07 14:31] INFO: Server 3 rate: 18.91 MiB/s', style: green },
        { text: '', style: muted },
        { text: '# Tip: Check current mirrors', style: muted },
        { text: '$ head -5 /etc/pacman.d/mirrorlist', style: white },
        { text: '# Updated on 2026-04-07', style: muted },
        { text: 'Server = https://mirror.f4st.host/archlinux/$repo/os/$arch', style: cyan },
        { text: 'Server = https://mirror.umd.edu/archlinux/$repo/os/$arch', style: cyan },
        { text: '', style: muted },
      ],
    ];

    let seqIndex = 0;

    function trimLines() {
      while (terminal.childElementCount > MAX_LINES) {
        terminal.removeChild(terminal.firstChild);
      }
    }

    function addLine(text, style, speed) {
      return new Promise((resolve) => {
        const el = document.createElement('div');
        el.style.cssText = style;
        terminal.appendChild(el);
        trimLines();
        terminal.scrollTop = terminal.scrollHeight;

        if (text === '') {
          resolve();
          return;
        }

        let i = 0;
        const rate = speed || (text.startsWith('$') ? 25 : 5);
        const type = () => {
          if (i < text.length) {
            el.textContent = text.substring(0, i + 1);
            i++;
            terminal.scrollTop = terminal.scrollHeight;
            setTimeout(type, rate + Math.random() * (rate / 3));
          } else {
            resolve();
          }
        };
        type();
      });
    }

    async function runSequence() {
      const seq = sequences[seqIndex % sequences.length];
      seqIndex++;

      for (const line of seq) {
        await addLine(line.text, line.style);
        await new Promise(r => setTimeout(r, line.text.startsWith('$') ? 500 : 40));
      }

      await new Promise(r => setTimeout(r, 1200));
      runSequence();
    }

    setTimeout(runSequence, 600);
  }
</script>
