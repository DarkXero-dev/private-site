---
// Contact tab — info card + status/weather terminal
---

<div class="max-w-4xl mx-auto flex flex-col gap-6 h-full justify-center">
  <h2 class="font-[family-name:var(--font-heading)] text-lg text-[var(--color-accent)] shrink-0">Contact</h2>

  <div class="info-card p-5 space-y-5 shrink-0">
    <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
      Want to get in touch? Whether it's about tech, a collaboration, or just to say hello &mdash;
      feel free to reach out.
    </p>

    <a href="mailto:info@techxero.com"
       class="inline-flex items-center gap-2.5 px-5 py-2.5 text-sm font-medium text-white bg-[var(--color-accent)] rounded-lg hover:bg-[var(--color-accent-light)] transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
      info@techxero.com
    </a>

    <div class="h-px bg-[var(--color-border)]"></div>

    <div class="space-y-3">
      <h3 class="font-[family-name:var(--font-heading)] text-xs text-[var(--color-text-muted)] uppercase tracking-widest">Find me elsewhere</h3>
      <div class="grid grid-cols-2 gap-3">
        <a href="https://github.com/DarkXero-dev" target="_blank" rel="noopener noreferrer" class="info-card p-3 flex items-center gap-2 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)]">
          <svg class="w-4 h-4" stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
          GitHub
        </a>
        <a href="https://mastodon.social/@TechXero" target="_blank" rel="noopener noreferrer" class="info-card p-3 flex items-center gap-2 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)]">
          <svg class="w-4 h-4" stroke="currentColor" fill="none" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21.327 8.566c0-4.339-2.843-5.61-2.843-5.61-1.433-.658-3.894-.935-6.451-.956h-.063c-2.557.021-5.016.298-6.45.956 0 0-2.843 1.272-2.843 5.61 0 .993-.019 2.181.012 3.441.103 4.243.778 8.425 4.701 9.463 1.809.479 3.362.579 4.612.51 2.268-.126 3.541-.809 3.541-.809l-.075-1.646s-1.621.511-3.441.449c-1.804-.062-3.707-.194-3.999-2.409a4.523 4.523 0 0 1-.04-.621s1.77.432 4.014.535c1.372.063 2.658-.08 3.965-.236 2.506-.299 4.688-1.843 4.962-3.254.434-2.223.398-5.424.398-5.424zm-3.353 5.59h-2.081V9.057c0-1.075-.452-1.62-1.357-1.62-1 0-1.501.647-1.501 1.927v2.791h-2.069V9.364c0-1.28-.501-1.927-1.502-1.927-.904 0-1.357.546-1.357 1.62v5.099H6.026V8.903c0-1.074.273-1.927.823-2.558.566-.631 1.307-.955 2.228-.955 1.065 0 1.872.41 2.405 1.228l.518.869.519-.869c.533-.818 1.34-1.228 2.405-1.228.92 0 1.662.324 2.228.955.549.631.822 1.484.822 2.558v5.253z"/></svg>
          Mastodon
        </a>
        <a href="https://linkedin.com/in/schaanine" target="_blank" rel="noopener noreferrer" class="info-card p-3 flex items-center gap-2 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)]">
          <svg class="w-4 h-4" stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          LinkedIn
        </a>
        <a href="https://www.youtube.com/@TechXeroLB" target="_blank" rel="noopener noreferrer" class="info-card p-3 flex items-center gap-2 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)]">
          <svg class="w-4 h-4" stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" stroke="none" fill="currentColor"/></svg>
          YouTube
        </a>
      </div>
    </div>
  </div>

  <!-- Section separator (desktop only) -->
  <div class="terminal-separator font-[family-name:var(--font-heading)] text-base font-bold text-[var(--color-text-muted)] text-center tracking-widest shrink-0">~~~~~~~~~~ Grid Information ~~~~~~~~~~</div>

  <!-- Status + Weather Terminal — sized to content -->
  <div class="hidden lg:flex lg:flex-col info-card p-0 overflow-hidden shrink-0">
    <!-- Title bar -->
    <div class="flex items-center gap-2 px-4 py-2.5 shrink-0 border-b border-[var(--color-border)]">
      <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
      <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
      <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
      <span class="font-[family-name:var(--font-mono)] text-[10px] text-[var(--color-text-muted)] ml-2">techxero@stationxero — status</span>
    </div>

    <!-- Terminal body — full width, full height -->
    <div id="contact-terminal" class="flex-1 flex flex-col font-[family-name:var(--font-mono)] text-[11px] leading-[1.6] overflow-hidden">

      <!-- Status bar -->
      <div class="flex flex-wrap gap-x-6 gap-y-1 px-4 py-2.5 shrink-0 border-b border-[var(--color-border)] text-[var(--color-text-muted)]">
        <span><span class="text-[var(--color-accent)]">TZ</span> <span id="status-tz">Europe/Belgrade (GMT+1)</span></span>
        <span><span class="text-[var(--color-accent)]">LOCAL</span> <span id="live-clock">--:--:--</span></span>
        <span><span class="text-[var(--color-accent)]">STATUS</span> <span class="text-[#4ade80]">● online</span></span>
        <span><span class="text-[var(--color-accent)]">LOC</span> <span id="status-loc">Novi Sad, Serbia</span></span>
      </div>

      <!-- Weather fills rest -->
      <div id="weather-box" class="flex-1 flex flex-col px-4 py-3 text-[var(--color-text-muted)]">
        <!-- Manual search row — hidden until auto-detect fails -->
        <div id="weather-search-row" class="hidden">
          <div class="flex items-center gap-2 shrink-0">
            <span class="text-[#4ade80]">$</span>
            <span class="text-[#4ade80]">weather</span>
            <span class="text-[var(--color-text-muted)]">--location</span>
            <form id="weather-location-form" class="flex items-center gap-1 flex-1 min-w-0">
              <input
                id="weather-location-input"
                type="text"
                autocomplete="off"
                spellcheck="false"
                class="bg-transparent outline-none text-[#e6edf3] font-[family-name:var(--font-mono)] text-[11px] flex-1 min-w-0 caret-[var(--color-accent)] border-b border-[var(--color-accent)]/50 focus:border-[var(--color-accent)] transition-colors pb-px"
                placeholder="Enter your city to see local weather"
              />
              <button type="submit" class="text-[var(--color-accent)] hover:text-[#e6edf3] text-[10px] transition-colors shrink-0">[↵]</button>
              <button type="button" id="weather-geolocate" title="Try detecting again" class="text-[var(--color-accent)] hover:text-[#e6edf3] text-[11px] transition-colors shrink-0 ml-1">📍</button>
            </form>
          </div>
          <div class="text-[10px] text-[var(--color-text-muted)]/60 mb-2 shrink-0 pl-4">✎ type a city or 📍 try detecting again</div>
        </div>
        <div id="weather-status" class="text-[10px] text-[var(--color-text-muted)] mb-1 shrink-0 hidden"></div>
        <div id="weather-content" class="flex-1 flex flex-col">
          <span class="text-[var(--color-text-muted)]">Fetching weather data...</span>
        </div>
      </div>
    </div>
  </div>

  <!-- End separator (desktop only) -->
  <div class="terminal-separator font-[family-name:var(--font-heading)] text-base font-bold text-[var(--color-text-muted)] text-center tracking-widest shrink-0">~~~~~~~~~~~ End - Of - Line ~~~~~~~~~~~</div>
</div>

<script>
  // Live clock — timezone updated dynamically once weather loads
  const clockEl = document.getElementById('live-clock');
  window._clockInterval = clockEl
    ? setInterval(() => { clockEl.textContent = new Date().toLocaleTimeString('en-GB', { timeZone: 'Europe/Belgrade', hour12: false }); }, 1000)
    : null;
  if (clockEl) clockEl.textContent = new Date().toLocaleTimeString('en-GB', { timeZone: 'Europe/Belgrade', hour12: false });

  // Weather
  const wBox = document.getElementById('weather-content');
  const wStatus = document.getElementById('weather-status');
  const wInput = document.getElementById('weather-location-input');
  const wForm = document.getElementById('weather-location-form');
  const wSearchRow = document.getElementById('weather-search-row');
  const statusTZ = document.getElementById('status-tz');
  const statusLOC = document.getElementById('status-loc');

  const showSearchRow = () => wSearchRow?.classList.remove('hidden');
  const hideSearchRow = () => wSearchRow?.classList.add('hidden');

  const updateStatusBar = (label, timezone, tzAbbr, utcOffsetSec) => {
    if (statusLOC) statusLOC.textContent = label;
    if (statusTZ && timezone) {
      const hrs = Math.round(utcOffsetSec / 3600);
      const sign = hrs >= 0 ? '+' : '-';
      statusTZ.textContent = `${timezone} (GMT${sign}${Math.abs(hrs)})`;
    }
  };

  if (wBox && window.innerWidth >= 1024) {
    const WMO_DESC = {
      0:'Clear sky', 1:'Mainly clear', 2:'Partly cloudy', 3:'Overcast',
      45:'Foggy', 48:'Icy fog',
      51:'Light drizzle', 53:'Drizzle', 55:'Heavy drizzle',
      56:'Freezing drizzle', 57:'Heavy freezing drizzle',
      61:'Slight rain', 63:'Moderate rain', 65:'Heavy rain',
      66:'Freezing rain', 67:'Heavy freezing rain',
      71:'Slight snow', 73:'Moderate snow', 75:'Heavy snow', 77:'Snow grains',
      80:'Slight showers', 81:'Showers', 82:'Violent showers',
      85:'Slight snow showers', 86:'Heavy snow showers',
      95:'Thunderstorm', 96:'Thunderstorm + hail', 99:'Heavy thunderstorm + hail'
    };
    const wmoArt = (code) => {
      if (code <= 1)  return ['    \\   /    ','     .-.     ','  ― (   ) ―  ','     `-\'     ','    /   \\    '];
      if (code === 2) return ['   \\  /      ',' _ /"".--.   ','   \\_(   ).  ','   /(___(__) ','             '];
      if (code === 3 || code === 45 || code === 48) return ['             ','     .--.    ','  .-(    ).  ',' (___.__)__) ','             '];
      if ([71,73,75,77,85,86].includes(code)) return ['     .-.     ','    (   ).   ','   (___(__)  ','   * * * *   ','  * * * *    '];
      if ([95,96,99].includes(code)) return ['     .-.     ','    (   ).   ','   (___(__)  ','  ⚡ʻ‚⚡ʻ‚   ','   ‚ʻ‚ʻ‚ʻ   '];
      return ['     .-.     ','    (   ).   ','   (___(__)  ','   ‚ʻ‚ʻ‚ʻ   ','   ‚ʻ‚ʻ‚ʻ   '];
    };
    const degToDir = (d) => {
      const dirs = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];
      return dirs[Math.round(d / 22.5) % 16];
    };
    const fmtTime = (iso) => iso ? iso.split('T')[1] : '--:--';
    const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

    const setStatus = (msg, isErr = false) => {
      if (!wStatus) return;
      wStatus.textContent = msg;
      wStatus.className = `text-[10px] mb-1 shrink-0 ${msg ? '' : 'hidden'} ${isErr ? 'text-[#f87171]' : 'text-[var(--color-text-muted)]'}`;
    };

    const renderWeather = (data, label) => {
      updateStatusBar(label, data.timezone, data.timezone_abbreviation, data.utc_offset_seconds);
      if (clockEl && data.timezone) {
        clearInterval(window._clockInterval);
        window._clockInterval = setInterval(() => {
          clockEl.textContent = new Date().toLocaleTimeString('en-GB', { timeZone: data.timezone, hour12: false });
        }, 1000);
        clockEl.textContent = new Date().toLocaleTimeString('en-GB', { timeZone: data.timezone, hour12: false });
      }
      hideSearchRow();
      const c = data.current;
      const d = data.daily;
      const code = c.weather_code;
      const desc = WMO_DESC[code] || 'Unknown';
      const art = wmoArt(code);
      const mk = (tag, cls, html) => { const e = document.createElement(tag); if (cls) e.className = cls; if (html) e.innerHTML = html; return e; };

      wBox.innerHTML = '';
      const sep = () => mk('div', 'w-full h-px bg-[var(--color-border)] my-2');

      wBox.appendChild(mk('div', 'text-[#e6edf3] font-bold mb-2', `Weather report: ${label}`));
      wBox.appendChild(sep());

      const row = mk('div', 'flex gap-4 items-start w-full my-1');
      const artBox = mk('pre', 'text-[#facc15] shrink-0 leading-[1.4]', art.join('\n'));
      artBox.style.fontSize = '11px';
      const details = mk('div', 'flex-1 grid grid-cols-2 gap-x-4 gap-y-1');
      details.innerHTML = `
        <div><span class="text-[var(--color-accent)]">Condition</span> <span class="text-[#e6edf3]">${desc}</span></div>
        <div><span class="text-[var(--color-accent)]">Temp</span> <span class="text-[#e6edf3]">${c.temperature_2m}°C</span> <span class="text-[var(--color-text-muted)]">(feels ${c.apparent_temperature}°C)</span></div>
        <div><span class="text-[var(--color-accent)]">Wind</span> <span class="text-[#e6edf3]">${c.wind_speed_10m} km/h ${degToDir(c.wind_direction_10m)}</span></div>
        <div><span class="text-[var(--color-accent)]">Humidity</span> <span class="text-[#e6edf3]">${c.relative_humidity_2m}%</span></div>
        <div><span class="text-[var(--color-accent)]">Pressure</span> <span class="text-[#e6edf3]">${c.surface_pressure} hPa</span></div>
        <div><span class="text-[var(--color-accent)]">UV Index</span> <span class="text-[#e6edf3]">${Math.round(c.uv_index)}</span></div>
        <div><span class="text-[var(--color-accent)]">Visibility</span> <span class="text-[#e6edf3]">${(c.visibility / 1000).toFixed(1)} km</span></div>
        <div><span class="text-[var(--color-accent)]">Clouds</span> <span class="text-[#e6edf3]">${c.cloud_cover}%</span></div>
      `;
      row.appendChild(artBox);
      row.appendChild(details);
      wBox.appendChild(row);
      wBox.appendChild(sep());

      wBox.appendChild(mk('div', 'text-[var(--color-accent)] text-[10px] uppercase tracking-widest mb-1', 'Forecast'));
      const fTable = mk('div', 'w-full grid grid-cols-[auto_1fr_1fr_1fr] gap-x-4 gap-y-0.5');
      d.time.forEach((date, i) => {
        const dayName = i === 0 ? 'Today' : days[new Date(date + 'T12:00:00').getDay()];
        fTable.innerHTML += `
          <span class="text-[#e6edf3]">${dayName}</span>
          <span><span class="text-[#4ade80]">↑ ${d.temperature_2m_max[i]}°C</span></span>
          <span><span class="text-[#22d3ee]">↓ ${d.temperature_2m_min[i]}°C</span></span>
          <span class="text-[var(--color-text-muted)]">${WMO_DESC[d.weather_code[i]] || 'Unknown'}</span>
        `;
      });
      wBox.appendChild(fTable);
      wBox.appendChild(sep());

      const aRow = mk('div', 'w-full grid grid-cols-2 gap-x-4 gap-y-0.5');
      aRow.innerHTML = `
        <div><span class="text-[var(--color-accent)]">Sunrise</span> <span class="text-[#e6edf3]">${fmtTime(d.sunrise[0])}</span></div>
        <div><span class="text-[var(--color-accent)]">Sunset</span> <span class="text-[#e6edf3]">${fmtTime(d.sunset[0])}</span></div>
      `;
      wBox.appendChild(aRow);

      const foot = mk('div', 'mt-auto pt-2 text-[10px] text-[var(--color-text-muted)] flex justify-between w-full');
      foot.innerHTML = `<span>${data.latitude.toFixed(4)}°N, ${data.longitude.toFixed(4)}°E</span><span>Updated: ${fmtTime(c.time)} local</span>`;
      wBox.appendChild(foot);
    };

    const fetchWeather = (lat, lon, label, timezone = 'auto') => {
      wBox.innerHTML = '<span class="text-[var(--color-text-muted)]">Fetching weather data...</span>';
      fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,relative_humidity_2m,apparent_temperature,weather_code,wind_speed_10m,wind_direction_10m,surface_pressure,cloud_cover,visibility,uv_index&daily=weather_code,temperature_2m_max,temperature_2m_min,sunrise,sunset&timezone=${timezone}&forecast_days=3`)
        .then(r => { if (!r.ok) throw new Error('fail'); return r.json(); })
        .then(data => { setStatus(''); renderWeather(data, label); })
        .catch(() => {
          wBox.innerHTML = `<pre class="text-[var(--color-text-muted)] whitespace-pre">
  Weather report: ${label}

       \\   /      Conditions:   --
        .-.       Temperature:  --°C
     ― (   ) ―   Wind:         -- km/h
        \`-'       Humidity:     --%
       /   \\      Visibility:   -- km

  Weather data temporarily unavailable.</pre>`;
        });
    };

    const geocodeAndFetch = (query) => {
      setStatus('Resolving location...');
      wBox.innerHTML = '<span class="text-[var(--color-text-muted)]">Resolving location...</span>';
      fetch(`https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(query)}&count=1&language=en&format=json`)
        .then(r => r.json())
        .then(geo => {
          if (!geo.results?.length) { setStatus(`Location not found: "${query}"`, true); wBox.innerHTML = ''; return; }
          const loc = geo.results[0];
          const label = [loc.name, loc.admin1, loc.country].filter(Boolean).join(', ');
          localStorage.setItem('weather_lat', loc.latitude);
          localStorage.setItem('weather_lon', loc.longitude);
          localStorage.setItem('weather_label', label);
          localStorage.setItem('weather_tz', loc.timezone || 'auto');
          if (wInput) wInput.value = '';
          setStatus('');
          hideSearchRow();
          fetchWeather(loc.latitude, loc.longitude, label, loc.timezone || 'auto');
        })
        .catch(() => setStatus('Geocoding failed. Try again.', true));
    };

    const applyLocation = (lat, lon) => {
      setStatus('Resolving city name...');
      fetch(`https://api.bigdatacloud.net/data/reverse-geocode-client?latitude=${lat}&longitude=${lon}&localityLanguage=en`)
        .then(r => r.json())
        .then(geo => {
          const city = geo.city || geo.locality || geo.principalSubdivision || 'Unknown';
          const region = geo.principalSubdivision || '';
          const country = geo.countryName || '';
          const label = [city, region !== city ? region : '', country].filter(Boolean).join(', ');
          localStorage.setItem('weather_lat', lat);
          localStorage.setItem('weather_lon', lon);
          localStorage.setItem('weather_label', label);
          localStorage.setItem('weather_tz', 'auto');
          if (wInput) wInput.value = '';
          setStatus('');
          fetchWeather(lat, lon, label, 'auto');
        })
        .catch(() => { fetchWeather(lat, lon, `${lat.toFixed(2)}°N, ${lon.toFixed(2)}°E`, 'auto'); setStatus(''); });
    };

    const ipFallback = () => {
      setStatus('Detecting location via IP...');
      fetch('https://ipapi.co/json/')
        .then(r => r.json())
        .then(d => {
          if (!d.latitude) throw new Error('no coords');
          applyLocation(d.latitude, d.longitude);
        })
        .catch(() => {
          setStatus('Could not detect location — enter your city below.', true);
          wBox.innerHTML = '';
          showSearchRow();
          wInput?.focus();
        });
    };

    const geolocateAndFetch = () => {
      setStatus('Detecting your location...');
      wBox.innerHTML = '<span class="text-[var(--color-text-muted)]">Detecting your location...</span>';
      if (!navigator.geolocation) { ipFallback(); return; }
      navigator.geolocation.getCurrentPosition(
        (pos) => applyLocation(pos.coords.latitude, pos.coords.longitude),
        (err) => err.code === 1 ? (setStatus('Location access denied — enter your city below.', true), wBox.innerHTML = '', showSearchRow(), wInput?.focus()) : ipFallback(),
        { timeout: 8000, enableHighAccuracy: false, maximumAge: 300000 }
      );
    };

    // Form submit handler
    if (wForm) {
      wForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const q = wInput?.value.trim();
        if (q) geocodeAndFetch(q);
      });
    }

    // 📍 button
    document.getElementById('weather-geolocate')?.addEventListener('click', geolocateAndFetch);

    // Load: saved → auto-detect (first visit) → default
    const savedLat = localStorage.getItem('weather_lat');
    const savedLon = localStorage.getItem('weather_lon');
    const savedLabel = localStorage.getItem('weather_label');
    const savedTz = localStorage.getItem('weather_tz');
    if (savedLat && savedLon && savedLabel) {
      if (wInput) wInput.value = '';
      fetchWeather(parseFloat(savedLat), parseFloat(savedLon), savedLabel, savedTz || 'auto');
    } else if (navigator.geolocation) {
      geolocateAndFetch();
    } else {
      fetchWeather(45.2671, 19.8335, 'Novi Sad, Vojvodina, Serbia', 'Europe/Belgrade');
    }
  }
</script>
