---
// The Vault — protected content at vault.techxero.com
---

<div class="max-w-4xl mx-auto space-y-4">
  <h2 class="font-[family-name:var(--font-heading)] text-lg text-[var(--color-accent)]">The Vault</h2>

  <p class="text-sm text-[var(--color-text-muted)]">
    Protected content &mdash; authentication required.
  </p>

  <!-- Gate overlay — CRT monitor -->
  <div id="vault-gate" class="vault-frame relative flex flex-col items-center justify-center overflow-hidden">
    <!-- Matrix rain background -->
    <canvas id="vault-matrix" class="absolute inset-0 opacity-12 rounded-[11px]"></canvas>

    <!-- Terminal-style header -->
    <div class="relative z-10 flex flex-col items-center gap-6">
      <!-- Lock icon -->
      <svg class="w-24 h-24 text-red-500/70 drop-shadow-[0_0_16px_rgba(239,68,68,0.45)] drop-shadow-[0_4px_8px_rgba(0,0,0,0.4)]" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
        <path d="M7 11V7a5 5 0 0110 0v4" />
        <circle cx="12" cy="16" r="1.5" fill="currentColor" stroke="none" />
        <line x1="12" y1="17.5" x2="12" y2="19.5" stroke-linecap="round" />
      </svg>

      <!-- Status lines -->
      <div class="font-[family-name:var(--font-mono)] text-[11px] space-y-1 text-center">
        <div class="text-[var(--color-accent)]">[ VAULT SYSTEMS — ENCRYPTED ]</div>
        <div class="text-cyan-500/50">AES-256-GCM &middot; ARGON2ID &middot; ZERO-KNOWLEDGE</div>
        <div class="vault-status-blink text-orange-400 mt-2">&#9608; AWAITING AUTHORIZATION...</div>
      </div>

      <!-- Unlock button -->
      <button
        id="vault-unlock"
        class="group flex items-center gap-3 px-6 py-3 rounded-xl border border-[var(--color-accent)]/40 bg-[var(--color-accent)]/10 hover:bg-[var(--color-accent)]/20 transition-all duration-300 cursor-pointer animate-[vault-pulse_3s_ease-in-out_infinite] font-[family-name:var(--font-mono)]"
      >
        <svg class="w-5 h-5 text-[var(--color-accent)] group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        <span class="text-sm text-[var(--color-accent)] tracking-wider uppercase">Unlock Vault</span>
      </button>

      <!-- Fingerprint hint -->
      <div class="font-[family-name:var(--font-mono)] text-[10px] text-cyan-500/30">
        CLEARANCE: LEVEL 5 REQUIRED &middot; SESSION: <span id="vault-session" class="text-[var(--color-accent)]/40"></span>
      </div>
    </div>
  </div>

  <!-- Iframe (hidden until unlocked) -->
  <iframe
    id="vault-iframe"
    data-src="https://vault.techxero.com"
    title="The Vault"
    class="vault-frame hidden"
  ></iframe>
</div>

<style>
  .vault-status-blink {
    animation: vault-blink 1.2s step-end infinite;
  }

  @keyframes vault-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>

<script>
  // Generate random session ID
  const sessionEl = document.getElementById('vault-session');
  if (sessionEl) {
    const hex = Array.from({ length: 8 }, () => Math.floor(Math.random() * 16).toString(16)).join('');
    sessionEl.textContent = `0x${hex.toUpperCase()}`;
  }

  // Matrix rain on canvas
  const canvas = document.getElementById('vault-matrix') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d');
    if (ctx) {
      const resize = () => { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight; };
      resize();
      window.addEventListener('resize', resize);

      const chars = 'アイウエオカキクケコサシスセソタチツテトナニヌネノ0123456789ABCDEF@#$%&';
      const fontSize = 12;
      const columns = Math.floor(canvas.width / fontSize);
      const drops: number[] = Array(columns).fill(1);

      function draw() {
        ctx!.fillStyle = 'rgba(4, 6, 16, 0.06)';
        ctx!.fillRect(0, 0, canvas.width, canvas.height);
        ctx!.fillStyle = '#22d3ee';
        ctx!.font = `${fontSize}px monospace`;

        for (let i = 0; i < drops.length; i++) {
          const char = chars[Math.floor(Math.random() * chars.length)];
          ctx!.fillText(char, i * fontSize, drops[i] * fontSize);
          if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) {
            drops[i] = 0;
          }
          drops[i]++;
        }
        requestAnimationFrame(draw);
      }
      draw();
    }
  }

  // Unlock handler
  document.getElementById('vault-unlock')?.addEventListener('click', () => {
    const gate = document.getElementById('vault-gate');
    const iframe = document.getElementById('vault-iframe') as HTMLIFrameElement;
    if (gate && iframe) {
      gate.classList.add('hidden');
      iframe.src = iframe.dataset.src || '';
      iframe.classList.remove('hidden');
    }
  });
</script>
